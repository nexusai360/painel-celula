# URL da API usada no build do front.
# - Dev: http://localhost:3000
# - Produção com a API servindo o front (serviço único): deixe VAZIO
#   (VITE_API_URL="") para o front usar caminho relativo (mesma origem).
# - Produção com front separado: aponte para a URL pública da API
#   (ex.: https://api.celula.nexusai360.com)
VITE_API_URL="http://localhost:3000"
