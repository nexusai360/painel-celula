# ── Banco de dados (Postgres) ──────────────────────────────────────────────
# Em produção, use a URL do seu Postgres gerenciado (Neon/Supabase/RDS/etc.).
DATABASE_URL="postgresql://icelula:icelula@localhost:5432/icelula?schema=public"

# ── Autenticação ───────────────────────────────────────────────────────────
# OBRIGATÓRIO em produção (a app se recusa a subir sem, quando NODE_ENV=production).
# Gere um segredo forte: openssl rand -hex 48
JWT_SECRET="dev-secret-troque-em-producao"

# ── Servidor ───────────────────────────────────────────────────────────────
NODE_ENV="development"          # em produção: "production"
API_PORT=3000                   # porta da API (alguns hosts injetam via outra variável)
HOST="0.0.0.0"                  # 0.0.0.0 aceita conexões externas (container/PaaS)
TZ="America/Sao_Paulo"          # IMPORTANTE: a janela de presença usa data local

# ── CORS ───────────────────────────────────────────────────────────────────
# Só necessário se o front estiver em OUTRO domínio (deploy separado).
# Origens permitidas separadas por vírgula. Vazio = libera qualquer origem (dev).
# Ex.: CORS_ORIGIN="https://celula.nexusai360.com"
CORS_ORIGIN=""

# URL do front (usada no redirect pós-login com Google).
WEB_URL="http://localhost:5173"

# ── Integração Google Calendar (opcional, DESLIGADA por padrão) ─────────────
# A feature fica off enquanto GOOGLE_OAUTH_ENABLED != "true".
GOOGLE_OAUTH_ENABLED="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"
# Chave de 32 bytes em hex (64 caracteres) para cifrar refresh tokens.
# Gere com: openssl rand -hex 32
TOKEN_ENC_KEY=""
