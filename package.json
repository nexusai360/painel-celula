{
  "name": "icelula",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace apps/api",
    "test": "npm run test --workspaces --if-present",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "app:up": "docker compose --profile full up -d --build",
    "app:down": "docker compose --profile full down",
    "app:logs": "docker compose --profile full logs -f app",
    "deploy": "node scripts/deploy.mjs",
    "deploy:status": "node scripts/deploy.mjs --status",
    "prisma:migrate": "npm run prisma:migrate --workspace apps/api",
    "prisma:seed": "npm run prisma:seed --workspace apps/api"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "prisma@6.19.3": true
  }
}
